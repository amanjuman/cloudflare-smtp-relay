# Cloudflare Email Service
CF_ACCOUNT_ID=
CF_API_TOKEN=

# Cloudflare DNS API (for DNS-01 challenge — needs Zone:DNS:Edit)
CF_DNS_API_TOKEN=

# SMTP auth credentials (clients use these to authenticate)
RELAY_USER=relay
RELAY_PASS=

# TLS / Let's Encrypt
CERT_DOMAIN=smtp.yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Optional
LISTEN_HOST=0.0.0.0
LISTEN_PORT=2525
LOG_LEVEL=INFO
